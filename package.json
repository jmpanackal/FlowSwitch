{
  "name": "flowswitch",
  "version": "0.1.0",
  "description": "Windows desktop app for profile-based workspace and window flows.",
  "author": "FlowSwitch",
  "main": "src/main/main.js",
  "scripts": {
    "predev": "node scripts/free-port.mjs 5173",
    "build": "vite build",
    "lint": "eslint \"src/**/*.js\" \"src/**/*.ts\" \"src/**/*.tsx\" \"eslint.config.cjs\" \"tailwind.config.js\" \"postcss.config.js\"",
    "typecheck": "node scripts/typecheck-baseline.mjs check",
    "typecheck:full": "tsc --noEmit",
    "typecheck:baseline:update": "node scripts/typecheck-baseline.mjs update",
    "test": "node --test src/main/utils/ src/main/services/",
    "dev:frontend": "vite",
    "dev:electron": "electron .",
    "dev": "npm-run-all -p dev:frontend dev:electron",
    "dev:launch-trace": "node scripts/dev-with-launch-trace.mjs",
    "dev:launch-automation": "node scripts/run-launch-automation.mjs",
    "dist:prepare": "npm run build",
    "dist:win": "npm run dist:prepare && electron-builder --win --x64 --publish never",
    "dist": "npm run dist:prepare && electron-builder --publish never",
    "website:sync-latest": "node scripts/sync-website-latest-json.mjs",
    "website:stage-downloads": "node scripts/stage-website-downloads.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^7.6.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^15.0.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.1",
    "vite": "^5.0.0",
    "wait-on": "^7.0.1"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.8",
    "clsx": "^2.1.1",
    "icon-extractor": "^1.0.3",
    "lucide-react": "^0.536.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.3.1",
    "windows-shortcuts": "^0.1.6",
    "winreg": "^1.2.5"
  },
  "build": {
    "appId": "app.flowswitch.desktop",
    "productName": "FlowSwitch",
    "copyright": "Copyright © FlowSwitch",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!website{,/**/*}",
      "!release{,/**/*}",
      "!**/.cursor{,/**/*}",
      "!**/.git{,/**/*}",
      "!**/.github{,/**/*}",
      "!.eslintcache",
      "!docs{,/**/*}"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "scripts/windows-shell-item-icon.ps1",
        "to": "scripts/windows-shell-item-icon.ps1"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/flowswitch-logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "FlowSwitch-${version}-win-${arch}-installer.${ext}"
    },
    "portable": {
      "artifactName": "FlowSwitch-${version}-win-${arch}-portable.${ext}"
    }
  }
}
